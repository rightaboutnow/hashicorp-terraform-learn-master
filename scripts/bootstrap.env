# bootstrap.env — config for scripts/bootstrap.sh (auto-sourced when present).
# Everything else has a sensible default; see SETUP.md for the full list.

export GITHUB_OWNER="rightaboutnow"                   # org/user that owns the repo
export GITHUB_REPO="hashicorp-terraform-learn-master" # repo name (must already exist)

# Shared Azure AD app reused across repos. Federated credentials are named per
# repo (<repo>-main, <repo>-env-<env>) so multiple repos can share one app.
export APP_NAME="github-actions-terraform"

# State storage. The bootstrap writes these into the repo's GitHub Actions
# variables (TFSTATE_RESOURCE_GROUP / TFSTATE_STORAGE_ACCOUNT / TFSTATE_CONTAINER),
# which the pipeline then uses for the Terraform backend -backend-config.
# Setting STATE_SA reuses the existing account (else the script derives a new name).
export STATE_RG="tfstate-rg"
export STATE_SA="tfstate439921213"
export STATE_CONTAINER="tfstate"
