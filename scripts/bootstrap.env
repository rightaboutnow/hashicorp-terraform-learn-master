# bootstrap.env — config for scripts/bootstrap.sh (auto-sourced when present).
# Only the two required values are here. Everything else has a sensible default;
# see SETUP.md for the full list of optional overrides.

export GITHUB_OWNER="rightaboutnow"     # org/user that owns the repo
export GITHUB_REPO="terraform-learn"    # repo name (must already exist)
